---
const skills = {
  Backend: [
    "Java (Spring Boot)",
    "Node.js (NestJS)",
    "Go (Gin/gRPC)",
    "Python (Django/FastAPI)",
    "Microservices",
    "REST/gRPC",
  ],
  Frontend: ["React", "Next.js", "Astro", "TypeScript", "TailwindCSS"],
  Database: ["PostgreSQL", "MongoDB", "Redis", "VectorDB"],
  DevOps: ["Docker", "Kubernetes", "CI/CD", "AWS/GCP", "Linux"],
  "Concepts & Tools": [
    "System Design",
    "Algorithms",
    "Git",
    "Kafka/RabbitMQ",
    "OAuth 2.0",
  ],
};
---

<section id="skills" class="py-20 border-t border-line">
  <div class="grid md:grid-cols-[10rem_1fr] gap-8">
    <h2 class="text-sm tracking-widest uppercase text-muted pt-1">Toolkit</h2>

    <div class="space-y-6 max-w-xl">
      {
        Object.entries(skills).map(([category, items]) => (
          <div class="grid grid-cols-[7rem_1fr] gap-4 items-baseline border-b border-line pb-5 last:border-0">
            <h3 class="text-sm text-accent">{category}</h3>
            <p class="text-ink/80 leading-relaxed">{items.join(", ")}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>
