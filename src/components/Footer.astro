---
const currentYear = new Date().getFullYear();
---

<footer id="contact" class="py-20 border-t border-line">
  <section class="grid md:grid-cols-[10rem_1fr] gap-8">
    <h2 class="text-sm tracking-widest uppercase text-muted pt-1">Contact</h2>

    <div class="max-w-xl">
      <p class="text-lg text-ink/80 leading-relaxed mb-8 max-w-md">
        Have a problem worth solving? Reach out with the form below, or find me
        on LinkedIn.
      </p>

      <form
        action="https://api.web3forms.com/submit"
        method="POST"
        class="space-y-5"
      >
        <input
          type="hidden"
          name="access_key"
          value="d29241db-555e-4ed4-9637-1f84296fd16f"
        />
        <div>
          <label for="name" class="block text-sm text-muted mb-2">Name</label>
          <input
            id="name"
            type="text"
            name="name"
            required
            class="w-full border-b border-line bg-transparent py-2 text-ink placeholder:text-muted focus:border-accent focus:outline-none"
          />
        </div>
        <div>
          <label for="email" class="block text-sm text-muted mb-2">Email</label>
          <input
            id="email"
            type="email"
            name="email"
            required
            class="w-full border-b border-line bg-transparent py-2 text-ink placeholder:text-muted focus:border-accent focus:outline-none"
          />
        </div>
        <div>
          <label for="message" class="block text-sm text-muted mb-2"
            >Message</label
          >
          <textarea
            id="message"
            name="message"
            required
            rows="4"
            class="w-full border-b border-line bg-transparent py-2 text-ink placeholder:text-muted focus:border-accent focus:outline-none resize-none"
          ></textarea>
        </div>
        <button
          type="submit"
          class="mt-2 inline-flex items-center border border-ink px-6 py-2.5 text-sm font-medium text-ink hover:bg-ink hover:text-paper transition-colors"
        >
          Send
        </button>
      </form>

      <div
        class="flex flex-wrap items-center justify-between gap-4 mt-16 pt-8 border-t border-line text-sm text-muted"
      >
        <p>&copy; {currentYear} Abdulselam Abdurehman</p>
        <div class="flex gap-6">
          <a
            href="https://github.com/AbdulselamAbdurehman"
            target="_blank"
            rel="noopener noreferrer"
            class="link-underline">GitHub</a
          >
          <a
            href="https://linkedin.com/in/abdulselam-abdurehman"
            target="_blank"
            rel="noopener noreferrer"
            class="link-underline">LinkedIn</a
          >
        </div>
      </div>
    </div>
  </section>
</footer>
