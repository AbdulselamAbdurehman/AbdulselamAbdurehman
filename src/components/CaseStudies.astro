---
interface CaseStudy {
  title: string;
  role: string;
  company: string;
  period: string;
  challenge: string;
  solution: string;
  outcome: string;
  tags: string[];
}

const caseStudies: CaseStudy[] = [
  {
    title: "High-Throughput Delivery Microservice",
    role: "Software Engineer",
    company: "Venas Technologies",
    period: "07/2025 – Present",
    challenge:
      "Existing routing solutions were costly and inefficient for batching orders, leading to high operational expenses and suboptimal rider utilization.",
    solution:
      "Developed a custom Compute Route Matrix solution and a real-time tracking system. Replaced per-sequence API calls with a batch-optimized algorithm capable of handling dynamic rerouting for up to 3 orders at a time.",
    outcome:
      "Projected 40% improvement in order assignment success rates and halved Google Maps usage costs through optimized batch routing.",
    tags: [
      "Microservices",
      "Real-time Systems",
      "Algorithm Optimization",
      "Google Maps Platform",
    ],
  },
  {
    title: "Comprehensive Fleet Management System",
    role: "Software Engineer",
    company: "AAU Startups",
    period: "02/2025 – 2/2026",
    challenge:
      "Startups incubators lacked a unified system to manage 400+ vehicles, fuel, trips, and compliance, relying on disjointed manual workflows.",
    solution:
      "Architected an end-to-end web application with modules for Vehicle, Fuel, and Trip management. Integrated GPS-based real-time tracking, geo-fencing, and automated reporting.",
    outcome:
      "Automated manual workflows, enhanced operational efficiency by 60%, and generated approximately 1M birr in cost savings.",
    tags: [
      "Full Stack",
      "GPS Integration",
      "System Architecture",
      "React",
      "Node.js",
    ],
  },
  {
    title: "National Blood & Tissue Bank System Modernization",
    role: "Software Engineering",
    company: "HabTech Solutions",
    period: "02/2025 – 06/2025",
    challenge:
      "A critical national legacy system running on Java 8 suffered from dependency conflicts, deprecated APIs, and undocumented customizations.",
    solution:
      "Led the migration to Java 21, resolving complex dependency conflicts and refactoring legacy code. Integrated device and SMS gateway functionalities for automated notifications.",
    outcome:
      "Successfully modernized the core application, ensuring system stability and regulatory compliance while maintaining all undocumented legacy customizations.",
    tags: [
      "Java 21",
      "Legacy Modernization",
      "SMS Gateway",
      "System Integration",
    ],
  },
];
---

<section id="projects" class="py-20 border-t border-line">
  <div class="grid md:grid-cols-[10rem_1fr] gap-8">
    <h2 class="text-sm tracking-widest uppercase text-muted pt-1">
      Selected Work
    </h2>

    <div class="space-y-16 max-w-xl">
      {
        caseStudies.map((project) => (
          <article>
            <div class="flex items-baseline justify-between gap-4 mb-1">
              <p class="text-sm text-accent">{project.company}</p>
              <span class="text-sm text-muted">{project.period}</span>
            </div>
            <h3 class="text-2xl mb-4">{project.title}</h3>

            <div class="space-y-3 text-ink/75 leading-relaxed">
              <p>{project.challenge}</p>
              <p>{project.solution}</p>
              <p class="border-l-2 border-accent pl-4 text-ink/90">
                {project.outcome}
              </p>
            </div>

            <ul class="flex flex-wrap gap-x-4 gap-y-1 mt-5 text-sm text-muted">
              {project.tags.map((tag) => (
                <li>{tag}</li>
              ))}
            </ul>
          </article>
        ))
      }
    </div>
  </div>
</section>
